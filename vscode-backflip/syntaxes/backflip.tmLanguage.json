{
  "scopeName": "backflip.injection",
  "injectionSelector": "L:text.html.basic",
  "patterns": [
    { "include": "#interpolation" },
    { "include": "#b-attributes" }
  ],
  "repository": {
    "interpolation": {
      "name": "meta.interpolation.backflip",
      "begin": "\\{\\{",
      "end": "\\}\\}",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.interpolation.begin.backflip" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.interpolation.end.backflip" }
      },
      "patterns": [
        {
          "name": "variable.other.backflip",
          "match": "[a-zA-Z_$][a-zA-Z0-9_$]*"
        },
        {
          "name": "punctuation.accessor.backflip",
          "match": "\\."
        }
      ]
    },
    "b-attributes": {
      "patterns": [
        {
          "name": "entity.other.attribute-name.directive.backflip",
          "match": "\\bb-(name|part|for|if|else-if|else|slot|in|export|unwrap|data:[a-zA-Z0-9_-]+|bind:[a-zA-Z0-9_-]+)\\b"
        },
        {
          "name": "entity.other.attribute-name.shorthand-bind.backflip",
          "match": "(?<=\\s):[a-zA-Z][a-zA-Z0-9_-]*"
        }
      ]
    }
  }
}
