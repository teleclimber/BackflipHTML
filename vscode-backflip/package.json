{
  "name": "vscode-backflip",
  "displayName": "BackflipHTML",
  "description": "Language support for BackflipHTML templates",
  "version": "0.1.0",
  "publisher": "backflip",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:html",
    "onLanguage:css",
    "workspaceContains:backflip.json"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "backflipHTML.openCssRule",
        "title": "BackflipHTML: Open CSS Rule"
      }
    ],
    "languages": [
      {
        "id": "html",
        "extensions": [
          ".html"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "scopeName": "backflip.injection",
        "path": "./syntaxes/backflip.tmLanguage.json",
        "injectTo": [
          "text.html.basic"
        ]
      }
    ]
  },
  "scripts": {
    "build": "npm run build:server && rollup -c rollup.config.mjs",
    "build:server": "cd ../lsp && npm run build && mkdir -p ../vscode-backflip/server && cp dist/server.cjs ../vscode-backflip/server/server.cjs",
    "watch": "npx tsc --watch"
  },
  "dependencies": {
    "@backflip/lsp": "file:../lsp",
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@rollup/plugin-commonjs": "^28.0.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@swc/core": "^1.15.21",
    "rollup": "^4.40.0",
    "rollup-plugin-swc3": "^0.12.1",
    "typescript": "^5.9.3"
  }
}
