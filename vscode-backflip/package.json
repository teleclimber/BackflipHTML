{
  "name": "vscode-backflip",
  "displayName": "BackflipHTML",
  "description": "Language support for BackflipHTML templates",
  "version": "0.1.0",
  "publisher": "backflip",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:html",
    "workspaceContains:backflip.json"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "html",
        "extensions": [
          ".html"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "scopeName": "backflip.injection",
        "path": "./syntaxes/backflip.tmLanguage.json",
        "injectTo": [
          "text.html.basic"
        ]
      }
    ]
  },
  "scripts": {
    "build": "npm run build:server && esbuild src/extension.ts --bundle --platform=node --format=cjs --external:vscode --outfile=dist/extension.js",
    "build:server": "cd ../lsp && npm run build && mkdir -p ../vscode-backflip/server && cp dist/server.js ../vscode-backflip/server/server.js",
    "watch": "tsc --watch"
  },
  "dependencies": {
    "@backflip/lsp": "file:../lsp",
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.27.4",
    "typescript": "^5.9.3"
  }
}
